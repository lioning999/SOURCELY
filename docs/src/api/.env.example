# ============================================================
# OfferCopilot 职通车AI — 环境变量模板
# 复制为 .env 并填入真实值。键名与 config.py 严格对齐。
# ============================================================

# ── 数据库 ──────────────────────────────────
DATABASE_HOST=127.0.0.1
DATABASE_PORT=3306
DATABASE_NAME=resume_db
DATABASE_USER=
DATABASE_PASSWORD=

# ── JWT ─────────────────────────────────────
JWT_SECRET_KEY=
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ── AI（DeepSeek / OpenAI 兼容 API）─────────
DASHSCOPE_API_KEY=
DASHSCOPE_BASE_URL=https://api.deepseek.com
AI_MODEL_NAME=deepseek-v4-pro
AI_REQUEST_TIMEOUT=60
AI_DIAGNOSE_TIMEOUT=120
AI_OPTIMIZE_TIMEOUT=180
AI_CONNECT_TIMEOUT=10
AI_MAX_RETRIES=3
AI_MAX_TOKENS=4096

# ── 微信登录 ────────────────────────────────
WECHAT_APPID=
WECHAT_SECRET=
WECHAT_LOGIN_URL=https://api.weixin.qq.com/sns/oauth2/access_token

# ── 微信支付 ────────────────────────────────
WECHAT_PAY_APPID=
WECHAT_PAY_MCH_ID=
WXPAY_APIV3_KEY=
WXPAY_CERT_SERIAL_NO=
WXPAY_PRIVATE_KEY_PATH=./cert/apiclient_key.pem
WXPAY_PUBLIC_KEY_ID=
WXPAY_PUBLIC_KEY_PATH=./cert/pub_key.pem
WECHAT_PAY_NOTIFY_URL=

# ── 业务常量 ────────────────────────────────
DEFAULT_PREVIEW_COUNT=2
PREVIEW_OPTIMIZE_RATIO=3
PLAN_1_PRICE=990
PLAN_1_TIMES=1
PLAN_2_PRICE=2990
PLAN_2_TIMES=5
RESUME_TEXT_MAX_LENGTH=10000
ALLOWED_EXTENSIONS=pdf,docx,txt
MAX_FILE_SIZE=5242880

# ── 服务器 ──────────────────────────────────
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
CORS_ORIGINS=*
DOMAIN=
TEST_MODE=true

# ── 日志 ────────────────────────────────────
LOG_LEVEL=INFO
LOG_DIR=./logs
